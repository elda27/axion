# Axion GCP Production Environment Configuration
# Copy this file to .env and fill in the values

# Application
APP_NAME=Axion
DEBUG=false

# Database (Cloud SQL)
DATABASE_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@localhost:5432/${DB_NAME}
DATABASE_TYPE=postgresql

# Object Storage (Google Cloud Storage)
OBJECT_STORE_PROVIDER=gcs
OBJECT_STORE_BUCKET=${GCS_BUCKET_NAME}
GCS_PROJECT_ID=${GCP_PROJECT_ID}
# GCS_CREDENTIALS_PATH is not needed when running on GCE with proper IAM

# API
API_PREFIX=/v1
