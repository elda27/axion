# Axion Lab Environment Configuration

# Application
DEBUG=false

# Docker Compose Ports (used by docker-compose.yml)
POSTGRES_PORT=5433
MINIO_API_PORT=9010
MINIO_CONSOLE_PORT=9011

# PostgreSQL Credentials (used by docker-compose.yml)
POSTGRES_USER=axion_lab
POSTGRES_PASSWORD=axion_lab_dev_password
POSTGRES_DB=axion_lab

# MinIO Credentials (used by docker-compose.yml)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Database (PostgreSQL for production, SQLite for local)
DATABASE_URL=postgresql+asyncpg://axion_lab:axion_lab_dev_password@localhost:5433/axion_lab
DATABASE_TYPE=postgresql

# For SQLite (local development without Docker):
# DATABASE_URL=sqlite+aiosqlite:///./axion_lab.db
# DATABASE_TYPE=sqlite

# Object Storage
OBJECT_STORE_PROVIDER=minio
OBJECT_STORE_ENDPOINT=http://localhost:9010
OBJECT_STORE_ACCESS_KEY=minioadmin
OBJECT_STORE_SECRET_KEY=minioadmin
OBJECT_STORE_BUCKET=axion-lab-artifacts
OBJECT_STORE_REGION=us-east-1

# For local file storage (without Docker):
# OBJECT_STORE_PROVIDER=local
# OBJECT_STORE_LOCAL_PATH=./data/object_store

# API
API_PREFIX=/v1
